# ============================================
# OBRAS PRO - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Seguranca
# Gere uma chave com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui-mude-para-producao

# Banco de Dados
# Desenvolvimento (SQLite)
DATABASE_URL=sqlite:///instance/obras_financeiro.db

# Producao (PostgreSQL)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/obras_financeiro

# OpenAI (Opcional - para Assistente IA)
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# Email (Opcional - para alertas automaticos)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app

# Cache (Opcional - para melhor performance)
# Desenvolvimento: simple
# Producao: redis
CACHE_TYPE=simple
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATELIMIT_DEFAULT=200/hour

# Deploy
# Defina FLASK_ENV=production em producao
FLASK_DEBUG=false
PORT=5000
