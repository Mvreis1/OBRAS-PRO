# ============================================
# OBRAS FINANCEIRO PRO - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Gere SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

# ==========================================
# Docker & Ports Configuration
# ==========================================
APP_PORT=5000
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==========================================
# PostgreSQL Database Configuration
# ==========================================
POSTGRES_DB=obras_financeiro
POSTGRES_USER=obras_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
# DATABASE_URL será montado automaticamente no docker-compose:
# postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ==========================================
# Application Settings
# ==========================================
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS_TOKEN_HEX_32
DEBUG_SECRET_KEY=

# ==========================================
# Security
# ==========================================
SESSION_COOKIE_SECURE=true
SESSION_LIFETIME=86400
ALLOWED_ORIGINS=https://obraspro.com.br,https://www.obraspro.com.br

# ==========================================
# Email (SMTP) Configuration
# ==========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=noreply@obraspro.com.br

# ==========================================
# AI APIs (Optional)
# ==========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

GEMINI_API_KEY=

CLAUDE_API_KEY=

# ==========================================
# AWS S3 / Cloud Storage (RECOMMENDED for Production)
# ==========================================
# Mantém uploads persistentes entre deploys no Render/Docker
# Funciona com AWS S3, Cloudflare R2, MinIO, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
# Para Cloudflare R2 ou MinIO (S3-compatible):
AWS_S3_ENDPOINT_URL=
# Para CDN customizado (CloudFront, etc):
AWS_S3_URL=

# ==========================================
# Cache & Rate Limiting
# ==========================================
# Docker: Redis configurado automaticamente
CACHE_TYPE=redis
REDIS_URL=redis://redis:6379/0
RATELIMIT_STORAGE_URL=redis://redis:6379/1
RATELIMIT_DEFAULT=200/hour

# ==========================================
# Gunicorn (Production)
# ==========================================
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=gthread
GUNICORN_THREADS=4
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
GUNICORN_ACCESS_LOG=-
GUNICORN_ERROR_LOG=-
GUNICORN_LOG_LEVEL=info
